rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CRManager Security Rules Philosophy
     * 
     * Core Philosophy: This ruleset implements a single-tenant corporate model where "Vendedores" (Sales Associates)
     * and "Admins" (Administrators) share access to the company's operational data. It uses a "Staff-Only" 
     * authorization model where access is gated by the presence of a user profile in the system.
     * 
     * Data Structure: 
     * - Global configuration is stored in /empresa.
     * - User roles and profiles are in /vendedores and /roles_admin.
     * - Most business entities (Clientes, Vendas, Atendimentos) are in top-level collections for shared access.
     * - User-specific targets (Metas) and schedules (Agenda) are scoped to individual staff members.
     * 
     * Key Security Decisions:
     * - Denormalization for Authorization: Critical IDs (clientId, vendedorId, etc.) are required on documents
     *   to allow rules to perform authorization checks without expensive get() calls.
     * - Structural Segregation: Administrative privileges are separated into a dedicated /roles_admin collection.
     * - Prototyping Flexibility: Schema validation is omitted to allow for rapid field changes, focusing 
     *   strictly on "Who can do what" and "Relational Integrity" (ensuring sub-items belong to their parents).
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isStaff() {
      return isSignedIn() && exists(/databases/$(database)/documents/vendedores/$(request.auth.uid));
    }

    function isAuthorized() {
      return isAdmin() || isStaff();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- COLLECTION RULES ---

    /**
     * @description Global company configuration. Access restricted to administrators.
     * @path /empresa/{empresaId}
     * @allow (get) Any authorized staff member.
     * @deny (write) Non-admin users.
     * @principle Role-based access control for master settings.
     */
    match /empresa/{empresaId} {
      allow get, list: if isAuthorized();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description User profiles for staff. Allows self-registration and admin management.
     * @path /vendedores/{vendedorId}
     * @allow (create) User creating their own profile matching their Auth UID.
     * @deny (update) Attempting to modify another staff member's profile.
     * @principle Self-creation and ownership for user profiles.
     */
    match /vendedores/{vendedorId} {
      allow get, list: if isAuthorized();
      allow create: if isOwner(vendedorId);
      allow update: if isExistingOwner(vendedorId) || isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Administrative role assignments.
     * @path /roles_admin/{adminUid}
     * @allow (read) Any staff member can verify roles.
     * @deny (write) Any non-admin user.
     * @principle Secure role management using existence-over-content pattern.
     */
    match /roles_admin/{adminUid} {
      allow get, list: if isAuthorized();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Customer master list.
     * @path /clientes/{clienteId}
     * @allow (create) Any authorized staff member.
     * @principle Shared corporate access for CRM data.
     */
    match /clientes/{clienteId} {
      allow get, list: if isAuthorized();
      allow create, update: if isAuthorized();
      allow delete: if isAdmin();

      /**
       * @description Children linked to a client.
       * @path /clientes/{clienteId}/filhos/{filhoId}
       * @allow (create) Setting the correct clientId that matches the parent path.
       * @principle Relational integrity between parent and child documents.
       */
      match /filhos/{filhoId} {
        allow get, list: if isAuthorized();
        allow create: if isAuthorized() && request.resource.data.clientId == clienteId;
        allow update: if isAuthorized() && (resource == null || request.resource.data.clientId == resource.data.clientId);
        allow delete: if isAuthorized();
      }
    }

    /**
     * @description Customer service records.
     * @path /atendimentos/{atendimentoId}
     * @allow (update) Any staff member updating a ticket status.
     * @principle Multi-user collaboration on support tickets.
     */
    match /atendimentos/{atendimentoId} {
      allow get, list: if isAuthorized();
      allow create, update: if isAuthorized();
      allow delete: if isAdmin();

      /**
       * @description Messages within a chat interaction.
       * @path /atendimentos/{atendimentoId}/mensagens/{mensagemId}
       */
      match /mensagens/{mensagemId} {
        allow get, list: if isAuthorized();
        allow create: if isAuthorized() && request.resource.data.atendimentoId == atendimentoId;
        allow update: if isAuthorized() && (resource == null || request.resource.data.atendimentoId == resource.data.atendimentoId);
        allow delete: if isAuthorized();
      }
    }

    /**
     * @description Sales transactions.
     * @path /vendas/{vendaId}
     */
    match /vendas/{vendaId} {
      allow get, list: if isAuthorized();
      allow create, update: if isAuthorized();
      allow delete: if isAdmin();

      /**
       * @description Items within a sale.
       */
      match /venda_itens/{vendaItemId} {
        allow get, list: if isAuthorized();
        allow create: if isAuthorized() && request.resource.data.vendaId == vendaId;
        allow update: if isAuthorized() && (resource == null || request.resource.data.vendaId == resource.data.vendaId);
        allow delete: if isAuthorized();
      }
    }

    /**
     * @description Product catalog and inventory management.
     * @path /produtos/{produtoId}
     */
    match /produtos/{produtoId} {
      allow get, list: if isAuthorized();
      allow create, update: if isAuthorized();
      allow delete: if isAdmin();

      /**
       * @description Stock movement history for a product.
       */
      match /movimentacoes_estoque/{movimentacaoEstoqueId} {
        allow get, list: if isAuthorized();
        allow create: if isAuthorized() && request.resource.data.produtoId == produtoId;
        allow update: if isAuthorized() && (resource == null || request.resource.data.produtoId == resource.data.produtoId);
        allow delete: if isAdmin();
      }
    }

    /**
     * @description Supplier directory.
     * @path /fornecedores/{fornecedorId}
     */
    match /fornecedores/{fornecedorId} {
      allow get, list: if isAuthorized();
      allow create, update: if isAuthorized();
      allow delete: if isAdmin();
    }

    /**
     * @description Purchase orders to suppliers.
     * @path /pedidos_compra/{pedidoCompraId}
     */
    match /pedidos_compra/{pedidoCompraId} {
      allow get, list: if isAuthorized();
      allow create, update: if isAuthorized();
      allow delete: if isAdmin();

      /**
       * @description Items within a purchase order.
       */
      match /pedido_compra_itens/{pedidoCompraItemId} {
        allow get, list: if isAuthorized();
        allow create: if isAuthorized() && request.resource.data.pedidoCompraId == pedidoCompraId;
        allow update: if isAuthorized() && (resource == null || request.resource.data.pedidoCompraId == resource.data.pedidoCompraId);
        allow delete: if isAuthorized();
      }
    }

    /**
     * @description Financial entries (Accounts Payable/Receivable).
     * @path /contas_financeiras/{contaFinanceiraId}
     */
    match /contas_financeiras/{contaFinanceiraId} {
      allow get, list: if isAuthorized();
      allow create, update: if isAuthorized();
      allow delete: if isAdmin();
    }

    /**
     * @description Bank account management.
     * @path /contas_bancarias/{contaBancariaId}
     */
    match /contas_bancarias/{contaBancariaId} {
      allow get, list: if isAuthorized();
      allow create, update: if isAuthorized();
      allow delete: if isAdmin();
    }

    /**
     * @description Chart of accounts for financial categorization.
     * @path /plano_contas/{planoContasId}
     */
    match /plano_contas/{planoContasId} {
      allow get, list: if isAuthorized();
      allow create, update: if isAuthorized();
      allow delete: if isAdmin();
    }

    /**
     * @description Individual sales targets. 
     * @path /metas/{metaId}
     * @allow (get) Admin or the salesperson the target belongs to.
     * @deny (create) Staff creating a target for a different user.
     * @principle Ownership-based visibility with admin override.
     */
    match /metas/{metaId} {
      allow get, list: if isAdmin() || (isStaff() && resource.data.vendedorId == request.auth.uid);
      allow create: if isAdmin() || (isStaff() && request.resource.data.vendedorId == request.auth.uid);
      allow update: if isAdmin() || (resource != null && isStaff() && resource.data.vendedorId == request.auth.uid);
      allow delete: if isAdmin();
    }

    /**
     * @description Marketing campaigns and performance metrics.
     * @path /campanhas_marketing/{campanhaMarketingId}
     */
    match /campanhas_marketing/{campanhaMarketingId} {
      allow get, list: if isAuthorized();
      allow create, update: if isAuthorized();
      allow delete: if isAdmin();
    }

    /**
     * @description Reusable message templates.
     * @path /templates_mensagem/{templateMensagemId}
     */
    match /templates_mensagem/{templateMensagemId} {
      allow get, list: if isAuthorized();
      allow create, update: if isAuthorized();
      allow delete: if isAdmin();
    }

    /**
     * @description Staff schedule and reminders.
     * @path /agenda_items/{agendaItemId}
     * @allow (list) Owner listing their own tasks.
     * @deny (update) Modifying a task assigned to another user.
     * @principle Individual ownership for personal workspace data.
     */
    match /agenda_items/{agendaItemId} {
      allow get, list: if isAdmin() || (isStaff() && resource.data.responsavelId == request.auth.uid);
      allow create: if isAdmin() || (isStaff() && request.resource.data.responsavelId == request.auth.uid);
      allow update: if isAdmin() || (resource != null && isStaff() && resource.data.responsavelId == request.auth.uid);
      allow delete: if isAdmin() || (resource != null && isStaff() && resource.data.responsavelId == request.auth.uid);
    }

  }
}