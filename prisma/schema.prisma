generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Company {
  id                                   String                 @id @default(uuid())
  cnpjCpf                              String                 @unique @map("cnpj_cpf")
  razaoSocial                          String                 @map("razao_social")
  nomeFantasia                         String                 @map("nome_fantasia")
  tipoPessoa                           String                 @default("PJ") @map("tipo_pessoa")
  telefone                             String?
  email                                String?
  createdAt                            DateTime               @default(now()) @map("created_at")
  updatedAt                            DateTime               @updatedAt @map("updated_at")
  allowNegativeStockOnManualAdjustment Boolean                @default(true) @map("allow_negative_stock_on_manual_adjustment")
  allowNegativeStockOnPDV              Boolean                @default(false) @map("allow_negative_stock_on_pdv")
  maxDiscountPercentage                Decimal                @default(100.00) @map("max_discount_percentage") @db.Decimal(5, 2)
  enableCustomerCredit                 Boolean                @default(false) @map("enable_customer_credit")
  enableSellerCommission               Boolean                @default(false) @map("enable_seller_commission")
  enableSellerGoals                    Boolean                @default(false) @map("enable_seller_goals")
  accountsReceivable                   AccountsReceivable[]
  activityLogs                         ActivityLog[]
  bankAccounts                         BankAccount[]
  cashMovements                        CashMovement[]
  cashRegisters                        CashRegister[]
  costCenters                          CostCenter[]
  customerTags                         CustomerTag[]
  customers                            Customer[]
  financialAccounts                    FinancialAccount[]
  financialTransactions                FinancialTransaction[]
  paymentMethods                       PaymentMethod[]
  productCategories                    ProductCategory[]
  products                             Product[]
  roles                                Role[]
  suppliers                            Supplier[]
  users                                User[]
  sales                                Sale[]
  exchangeReturns                      ExchangeReturn[]

  @@map("companies")
}

model Role {
  id          String       @id @default(uuid())
  companyId   String       @map("company_id")
  name        String
  description String?
  isAdmin     Boolean      @default(false) @map("is_admin")
  maxDiscountPercentage Decimal?     @map("max_discount_percentage") @db.Decimal(5, 2)
  status      String       @default("ACTIVE")
  createdAt   DateTime     @default(now()) @map("created_at")
  permissions Permission[]
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users       User[]

  @@unique([companyId, name])
  @@map("roles")
}

model Permission {
  id      String  @id @default(uuid())
  roleId  String  @map("role_id")
  module  String
  action  String
  allowed Boolean @default(false)
  role    Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, module, action])
  @@map("permissions")
}

model User {
  id                    String                 @id @default(uuid())
  companyId             String                 @map("company_id")
  roleId                String?                @map("role_id")
  name                  String
  username              String?                @unique
  email                 String                 @unique
  pinAccessHash         String                 @map("pin_access_hash")
  status                String                 @default("ACTIVE")
  cargo                 String?
  permitirAcesso        Boolean                @default(true) @map("permitir_acesso")
  isSeller              Boolean                @default(false) @map("is_seller")
  sellerCode            String?                @map("seller_code")
  commissionRate        Decimal                @default(0.00) @map("commission_rate") @db.Decimal(5, 2)
  maxDiscountPercentage Decimal?               @map("max_discount_percentage") @db.Decimal(5, 2)
  pinLastChangedAt      DateTime?              @map("pin_last_changed_at")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  activityLogs          ActivityLog[]
  cashMovements         CashMovement[]         @relation("CashMovementCreatedBy")
  cashRegistersClosed   CashRegister[]         @relation("CashRegisterClosedBy")
  cashRegistersOpened   CashRegister[]         @relation("CashRegisterOpenedBy")
  financialTransactions FinancialTransaction[] @relation("FinancialTransactionCreatedBy")
  company               Company                @relation(fields: [companyId], references: [id])
  role                  Role?                  @relation(fields: [roleId], references: [id])
  inventoryMovements    InventoryMovement[]
  sales                 Sale[]                 @relation("SaleSeller")
  cancelledSales        Sale[]                 @relation("SaleCancelledBy")
  saleAuthorizationsRequested SaleAuthorization[] @relation("AuthRequestedBy")
  saleAuthorizationsApproved  SaleAuthorization[] @relation("AuthApprovedBy")
  sellerGoals           SellerGoal[]
  sellerCommissions     SellerCommission[]

  @@map("users")
}

model ActivityLog {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  userId    String   @map("user_id")
  action    String
  module    String
  recordId  String?  @map("record_id")
  details   String?
  createdAt DateTime @default(now()) @map("created_at")
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}

model Customer {
  id                 String   @id @default(uuid())
  companyId          String   @map("company_id")
  name               String
  email              String?
  phone              String // Telefone principal
  cpf                String?
  birthDay           Int?     @map("birth_day")
  birthMonth         Int?     @map("birth_month")
  birthYear          Int?     @map("birth_year")
  instagram          String?
  notes              String?  @db.Text
  status             String   @default("ativo") // ativo, inativo, arquivado
  phoneIsPlaceholder Boolean  @default(false) @map("phone_is_placeholder")
  needsPhoneReview   Boolean  @default(false) @map("needs_phone_review")
  legacyFirebaseId   String?  @unique @map("legacy_firebase_id")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  company        Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  children       CustomerChild[]
  tagRelations   CustomerTagRelation[]
  wallet         CustomerWallet?
  historyEntries CustomerHistory[]
  interactions   CustomerInteraction[]
  receivables    AccountsReceivable[]
  sales          Sale[]

  // Cada telefone deve ser único por empresa
  @@unique([companyId, phone])
  @@map("customers")
}

model CustomerChild {
  id               String    @id @default(uuid())
  customerId       String    @map("customer_id")
  name             String
  birthDate        DateTime? @map("birth_date")
  gender           String?
  shoeSize         String?   @map("shoe_size")
  clothingSize     String?   @map("clothing_size")
  notes            String?
  legacyFirebaseId String?   @map("legacy_firebase_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  customer         Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_children")
}

model CustomerTag {
  id               String                @id @default(uuid())
  companyId        String                @map("company_id")
  name             String
  color            String?
  legacyFirebaseId String?               @map("legacy_firebase_id")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")
  relations        CustomerTagRelation[]
  company          Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@map("customer_tags")
}

model CustomerTagRelation {
  id         String      @id @default(uuid())
  customerId String      @map("customer_id")
  tagId      String      @map("tag_id")
  createdAt  DateTime    @default(now()) @map("created_at")
  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tag        CustomerTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([customerId, tagId])
  @@map("customer_tag_relations")
}

model CustomerWallet {
  id         String                   @id @default(uuid())
  customerId String                   @unique @map("customer_id")
  balance    Decimal                  @default(0.0) @db.Decimal(10, 2)
  createdAt  DateTime                 @default(now()) @map("created_at")
  updatedAt  DateTime                 @updatedAt @map("updated_at")
  movements  CustomerWalletMovement[]
  customer   Customer                 @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_wallets")
}

model CustomerWalletMovement {
  id               String         @id @default(uuid())
  walletId         String         @map("wallet_id")
  amount           Decimal        @db.Decimal(10, 2)
  type             String
  reason           String?
  legacyFirebaseId String?        @map("legacy_firebase_id")
  createdAt        DateTime       @default(now()) @map("created_at")
  wallet           CustomerWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@map("customer_wallet_movements")
}

model CustomerHistory {
  id          String   @id @default(uuid())
  customerId  String   @map("customer_id")
  actionType  String   @map("action_type")
  description String
  createdAt   DateTime @default(now()) @map("created_at")
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_histories")
}

model CustomerInteraction {
  id         String   @id @default(uuid())
  customerId String   @map("customer_id")
  type       String
  notes      String
  createdAt  DateTime @default(now()) @map("created_at")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_interactions")
}

model ProductCategory {
  id               String    @id @default(uuid())
  companyId        String    @map("company_id")
  name             String
  description      String?
  isActive         Boolean   @default(true) @map("is_active")
  archivedAt       DateTime? @map("archived_at")
  legacyFirebaseId String?   @map("legacy_firebase_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products         Product[]

  @@unique([companyId, name])
  @@index([name])
  @@map("product_categories")
}

model Supplier {
  id               String    @id @default(uuid())
  companyId        String    @map("company_id")
  name             String
  cnpjCpf          String?   @map("cnpj_cpf")
  email            String?
  phone            String?
  isActive         Boolean   @default(true) @map("is_active")
  archivedAt       DateTime? @map("archived_at")
  legacyFirebaseId String?   @map("legacy_firebase_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  products         Product[]
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([name])
  @@map("suppliers")
}

model Product {
  id               String                @id @default(uuid())
  companyId        String                @map("company_id")
  categoryId       String?               @map("category_id")
  supplierId       String?               @map("supplier_id")
  name             String
  internalCode     String                @map("internal_code")
  description      String?
  imageUrl         String?               @map("image_url")
  thumbnailUrl     String?               @map("thumbnail_url")
  galleryUrls      String[]              @map("gallery_urls")
  isActive         Boolean               @default(true) @map("is_active")
  archivedAt       DateTime?             @map("archived_at")
  legacyFirebaseId String?               @map("legacy_firebase_id")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")
  priceHistories   ProductPriceHistory[]
  variants         ProductVariant[]
  category         ProductCategory?      @relation(fields: [categoryId], references: [id])
  company          Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplier         Supplier?             @relation(fields: [supplierId], references: [id])

  @@unique([companyId, internalCode])
  @@index([name])
  @@index([internalCode])
  @@map("products")
}

model ProductVariant {
  id                 String              @id @default(uuid())
  productId          String              @map("product_id")
  sku                String              @unique
  barcode            String?
  barcodeType        String?             @map("barcode_type")
  name               String
  costPrice          Decimal             @map("cost_price") @db.Decimal(10, 2)
  salePrice          Decimal             @map("sale_price") @db.Decimal(10, 2)
  currentStock       Decimal             @default(0.00) @map("current_stock") @db.Decimal(10, 2)
  reservedStock      Decimal             @default(0.00) @map("reserved_stock") @db.Decimal(10, 2)
  minimumStock       Decimal             @default(0.00) @map("minimum_stock") @db.Decimal(10, 2)
  availableStock     Decimal             @default(0.00) @map("available_stock") @db.Decimal(10, 2)
  isActive           Boolean             @default(true) @map("is_active")
  archivedAt         DateTime?           @map("archived_at")
  legacyFirebaseId   String?             @map("legacy_firebase_id")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  inventoryMovements InventoryMovement[]
  saleItems          SaleItem[]
  exchangeReturnItems ExchangeReturnItem[]
  product            Product             @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([sku])
  @@index([barcode])
  @@map("product_variants")
}

model ProductPriceHistory {
  id              String   @id @default(uuid())
  productId       String   @map("product_id")
  oldCostPrice    Decimal  @map("old_cost_price") @db.Decimal(10, 2)
  newCostPrice    Decimal  @map("new_cost_price") @db.Decimal(10, 2)
  oldSalePrice    Decimal  @map("old_sale_price") @db.Decimal(10, 2)
  newSalePrice    Decimal  @map("new_sale_price") @db.Decimal(10, 2)
  changedByUserId String?  @map("changed_by_user_id")
  changeReason    String?  @map("change_reason")
  changedAt       DateTime @default(now()) @map("changed_at")
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_price_histories")
}

model InventoryMovement {
  id               String                @id @default(uuid())
  variantId        String                @map("variant_id")
  quantity         Decimal               @db.Decimal(10, 2)
  type             InventoryMovementType
  reason           String?
  warehouseId      String                @default("LOJA_PRINCIPAL") @map("warehouse_id")
  legacyFirebaseId String?               @map("legacy_firebase_id")
  userId           String?               @map("user_id")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")
  variant          ProductVariant        @relation(fields: [variantId], references: [id], onDelete: Cascade)
  user             User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("inventory_movements")
}

model BankAccount {
  id               String                 @id @default(uuid())
  companyId        String                 @map("company_id")
  name             String
  bankName         String?                @map("bank_name")
  accountNumber    String?                @map("account_number")
  agency           String?
  pixKey           String?                @map("pix_key")
  initialBalance   Decimal                @default(0.00) @map("initial_balance") @db.Decimal(15, 2)
  currentBalance   Decimal                @default(0.00) @map("current_balance") @db.Decimal(15, 2)
  isCashAccount    Boolean                @default(false) @map("is_cash_account")
  isActive         Boolean                @default(true) @map("is_active")
  archivedAt       DateTime?              @map("archived_at")
  legacyFirebaseId String?                @map("legacy_firebase_id")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")
  company          Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  cashRegisters    CashRegister[]
  transactions     FinancialTransaction[]

  @@index([companyId, isActive])
  @@map("bank_accounts")
}

model CostCenter {
  id           String                 @id @default(uuid())
  companyId    String                 @map("company_id")
  name         String
  code         String?
  description  String?
  isActive     Boolean                @default(true) @map("is_active")
  archivedAt   DateTime?              @map("archived_at")
  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")
  company      Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  transactions FinancialTransaction[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("cost_centers")
}

model FinancialAccount {
  id               String                 @id @default(uuid())
  companyId        String                 @map("company_id")
  parentId         String?                @map("parent_id")
  code             String
  name             String
  type             String
  acceptsEntries   Boolean                @default(true) @map("accepts_entries")
  isActive         Boolean                @default(true) @map("is_active")
  archivedAt       DateTime?              @map("archived_at")
  legacyFirebaseId String?                @map("legacy_firebase_id")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")
  receivables      AccountsReceivable[]
  company          Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent           FinancialAccount?      @relation("AccountHierarchy", fields: [parentId], references: [id])
  children         FinancialAccount[]     @relation("AccountHierarchy")
  transactions     FinancialTransaction[]

  @@unique([companyId, code])
  @@index([companyId, type])
  @@map("financial_accounts")
}

model PaymentMethod {
  id                    String                 @id @default(uuid())
  companyId             String                 @map("company_id")
  name                  String
  type                  PaymentMethodType
  allowsInstallments    Boolean                @default(false) @map("allows_installments")
  autoReceive           Boolean                @default(false) @map("auto_receive")
  requiresAuthorization Boolean                @default(false) @map("requires_authorization")
  feePercentage         Decimal                @default(0.00) @map("fee_percentage") @db.Decimal(5, 4)
  settlementDays        Int                    @default(0) @map("settlement_days")
  isSystemDefault       Boolean                @default(false) @map("is_system_default")
  isActive              Boolean                @default(true) @map("is_active")
  archivedAt            DateTime?              @map("archived_at")
  legacyFirebaseId      String?                @map("legacy_firebase_id")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  transactions          FinancialTransaction[]
  salePayments          SalePayment[]
  company               Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId, isActive])
  @@map("payment_methods")
}

model CashRegister {
  id              String                 @id @default(uuid())
  companyId       String                 @map("company_id")
  openedByUserId  String                 @map("opened_by_user_id")
  closedByUserId  String?                @map("closed_by_user_id")
  bankAccountId   String                 @map("bank_account_id")
  terminalId      String?                @map("terminal_id")
  deviceId        String?                @map("device_id")
  openedAt        DateTime               @default(now()) @map("opened_at")
  closedAt        DateTime?              @map("closed_at")
  openingBalance  Decimal                @default(0.00) @map("opening_balance") @db.Decimal(15, 2)
  closingBalance  Decimal?               @map("closing_balance") @db.Decimal(15, 2)
  expectedBalance Decimal?               @map("expected_balance") @db.Decimal(15, 2)
  difference      Decimal?               @db.Decimal(15, 2)
  status          CashRegisterStatus     @default(OPEN)
  notes           String?
  movements       CashMovement[]
  bankAccount     BankAccount            @relation(fields: [bankAccountId], references: [id])
  closedBy        User?                  @relation("CashRegisterClosedBy", fields: [closedByUserId], references: [id])
  company         Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  openedBy        User                   @relation("CashRegisterOpenedBy", fields: [openedByUserId], references: [id])
  transactions    FinancialTransaction[]
  sales           Sale[]

  @@index([companyId, status])
  @@index([openedAt])
  @@map("cash_registers")
}

model FinancialTransaction {
  id                 String                     @id @default(uuid())
  companyId          String                     @map("company_id")
  type               FinancialTransactionType
  direction          String
  status             FinancialTransactionStatus @default(PENDING)
  bankAccountId      String?                    @map("bank_account_id")
  cashRegisterId     String?                    @map("cash_register_id")
  paymentMethodId    String?                    @map("payment_method_id")
  costCenterId       String?                    @map("cost_center_id")
  financialAccountId String?                    @map("financial_account_id")
  customerId         String?                    @map("customer_id")
  referenceType      String?                    @map("reference_type")
  referenceId        String?                    @map("reference_id")
  sourceModule       String?                    @map("source_module")
  externalReference  String?                    @map("external_reference")
  description        String
  amount             Decimal                    @db.Decimal(15, 2)
  dueDate            DateTime?                  @map("due_date")
  paidAt             DateTime?                  @map("paid_at")
  legacyFirebaseId   String?                    @map("legacy_firebase_id")
  createdByUserId    String                     @map("created_by_user_id")
  createdAt          DateTime                   @default(now()) @map("created_at")
  updatedAt          DateTime                   @updatedAt @map("updated_at")
  receivables        AccountsReceivable[]
  bankAccount        BankAccount?               @relation(fields: [bankAccountId], references: [id])
  cashRegister       CashRegister?              @relation(fields: [cashRegisterId], references: [id])
  company            Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  costCenter         CostCenter?                @relation(fields: [costCenterId], references: [id])
  createdBy          User                       @relation("FinancialTransactionCreatedBy", fields: [createdByUserId], references: [id])
  financialAccount   FinancialAccount?          @relation(fields: [financialAccountId], references: [id])
  paymentMethod      PaymentMethod?             @relation(fields: [paymentMethodId], references: [id])

  @@index([companyId, type, status])
  @@index([companyId, dueDate])
  @@index([companyId, paidAt])
  @@index([cashRegisterId])
  @@index([customerId])
  @@map("financial_transactions")
}

model AccountsReceivable {
  id                     String                  @id @default(uuid())
  companyId              String                  @map("company_id")
  customerId             String?                 @map("customer_id")
  financialTransactionId String?                 @map("financial_transaction_id")
  financialAccountId     String?                 @map("financial_account_id")
  installmentNumber      Int                     @default(1) @map("installment_number")
  totalInstallments      Int                     @default(1) @map("total_installments")
  originalAmount         Decimal                 @map("original_amount") @db.Decimal(15, 2)
  paidAmount             Decimal                 @default(0.00) @map("paid_amount") @db.Decimal(15, 2)
  remainingAmount        Decimal                 @map("remaining_amount") @db.Decimal(15, 2)
  dueDate                DateTime                @map("due_date")
  paidAt                 DateTime?               @map("paid_at")
  status                 AccountReceivableStatus @default(PENDING)
  notes                  String?
  legacyFirebaseId       String?                 @map("legacy_firebase_id")
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")
  company                Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer               Customer?               @relation(fields: [customerId], references: [id])
  financialAccount       FinancialAccount?       @relation(fields: [financialAccountId], references: [id])
  financialTransaction   FinancialTransaction?   @relation(fields: [financialTransactionId], references: [id])

  @@index([companyId, status])
  @@index([companyId, dueDate])
  @@index([customerId])
  @@map("accounts_receivable")
}

model CashMovement {
  id              String       @id @default(uuid())
  companyId       String       @map("company_id")
  cashRegisterId  String       @map("cash_register_id")
  type            String
  amount          Decimal      @db.Decimal(15, 2)
  description     String?
  createdByUserId String       @map("created_by_user_id")
  createdAt       DateTime     @default(now()) @map("created_at")
  cashRegister    CashRegister @relation(fields: [cashRegisterId], references: [id], onDelete: Cascade)
  company         Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy       User         @relation("CashMovementCreatedBy", fields: [createdByUserId], references: [id])

  @@index([cashRegisterId])
  @@index([companyId, createdAt])
  @@map("cash_movements")
}

enum InventoryMovementType {
  INITIAL
  PURCHASE
  SALE
  RETURN
  EXCHANGE
  LOSS
  DAMAGE
  MANUAL_ADJUSTMENT
  TRANSFER
  RESERVATION
  CANCELLATION
}

enum FinancialTransactionType {
  INCOME
  EXPENSE
  TRANSFER
  CASH_IN
  CASH_OUT
}

enum FinancialTransactionStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
  PARTIAL
}

enum CashRegisterStatus {
  OPEN
  CLOSED
  SUSPENDED
}

enum PaymentMethodType {
  CASH
  DEBIT_CARD
  CREDIT_CARD
  PIX
  BANK_TRANSFER
  STORE_CREDIT
  CUSTOMER_WALLET
  CHECK
  OTHER
}

enum AccountReceivableStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
  RENEGOTIATED
}

enum SaleStatus {
  DRAFT
  PENDING
  PAID
  CANCELLED
  PARTIALLY_RETURNED
  RETURNED
}

enum SaleAuthorizationType {
  DISCOUNT_OVER_LIMIT
  CANCEL_SALE
}

enum SaleAuthorizationStatus {
  PENDING
  APPROVED
  DENIED
}

enum SellerCommissionStatus {
  PENDING
  PAID
  CANCELLED
}

enum ExchangeReturnType {
  EXCHANGE
  RETURN
  WARRANTY
  DAMAGE
}

enum ExchangeReturnStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum ExchangeReturnCondition {
  RESALE
  DAMAGED
  DISCARD
}

model Sale {
  id                    String      @id @default(uuid())
  companyId             String      @map("company_id")
  customerId            String?     @map("customer_id")
  sellerId              String      @map("seller_id")
  cashRegisterId        String?     @map("cash_register_id")
  
  status                SaleStatus  @default(PENDING)
  subtotal              Decimal     @db.Decimal(15, 2)
  discountAmount        Decimal     @default(0.00) @map("discount_amount") @db.Decimal(15, 2)
  totalAmount           Decimal     @db.Decimal(15, 2)
  notes                 String?

  customerNameSnapshot  String?     @map("customer_name_snapshot")
  customerPhoneSnapshot String?     @map("customer_phone_snapshot")

  cancelReason          String?     @map("cancel_reason")
  cancelledByUserId     String?     @map("cancelled_by_user_id")
  cancelledAt           DateTime?   @map("cancelled_at")

  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")

  company               Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer              Customer?   @relation(fields: [customerId], references: [id])
  seller                User        @relation("SaleSeller", fields: [sellerId], references: [id])
  cashRegister          CashRegister? @relation(fields: [cashRegisterId], references: [id])
  cancelledBy           User?       @relation("SaleCancelledBy", fields: [cancelledByUserId], references: [id])

  items                 SaleItem[]
  payments              SalePayment[]
  authorizations        SaleAuthorization[]
  commissions           SellerCommission[]

  @@index([companyId, status])
  @@index([createdAt])
  @@index([sellerId])
  @@index([customerId])
  @@map("sales")
}

model SaleItem {
  id                    String      @id @default(uuid())
  saleId                String      @map("sale_id")
  variantId             String      @map("variant_id")
  
  productNameSnapshot   String      @map("product_name_snapshot")
  variantNameSnapshot   String      @map("variant_name_snapshot")
  skuSnapshot           String      @map("sku_snapshot")
  barcodeSnapshot       String?     @map("barcode_snapshot")

  quantity              Decimal     @db.Decimal(10, 2)
  unitPrice             Decimal     @map("unit_price") @db.Decimal(15, 2)
  discount              Decimal     @default(0.00) @db.Decimal(15, 2)
  totalPrice            Decimal     @map("total_price") @db.Decimal(15, 2)

  costPriceAtSale       Decimal     @map("cost_price_at_sale") @db.Decimal(15, 2)
  salePriceAtSale       Decimal     @map("sale_price_at_sale") @db.Decimal(15, 2)
  marginAtSale          Decimal     @map("margin_at_sale") @db.Decimal(5, 2)

  sale                  Sale        @relation(fields: [saleId], references: [id], onDelete: Cascade)
  variant               ProductVariant @relation(fields: [variantId], references: [id])

  @@index([skuSnapshot])
  @@index([barcodeSnapshot])
  @@map("sale_items")
}

model SalePayment {
  id                    String      @id @default(uuid())
  saleId                String      @map("sale_id")
  paymentMethodId       String      @map("payment_method_id")
  amount                Decimal     @db.Decimal(15, 2)
  installments          Int         @default(1)
  status                String      @default("PENDING")

  sale                  Sale        @relation(fields: [saleId], references: [id], onDelete: Cascade)
  paymentMethod         PaymentMethod @relation(fields: [paymentMethodId], references: [id])

  @@map("sale_payments")
}

model SaleAuthorization {
  id                    String      @id @default(uuid())
  saleId                String      @map("sale_id")
  requestedByUserId     String      @map("requested_by_user_id")
  authorizedByUserId    String?     @map("authorized_by_user_id")
  type                  SaleAuthorizationType
  status                SaleAuthorizationStatus @default(PENDING)
  reason                String?
  requestedDiscount     Decimal     @map("requested_discount") @db.Decimal(10, 2)
  allowedDiscount       Decimal     @map("allowed_discount") @db.Decimal(10, 2)
  createdAt             DateTime    @default(now()) @map("created_at")

  sale                  Sale        @relation(fields: [saleId], references: [id], onDelete: Cascade)
  requestedBy           User        @relation("AuthRequestedBy", fields: [requestedByUserId], references: [id])
  authorizedBy          User?       @relation("AuthApprovedBy", fields: [authorizedByUserId], references: [id])

  @@map("sale_authorizations")
}

model SellerGoal {
  id                    String      @id @default(uuid())
  userId                String      @map("user_id")
  periodStart           DateTime    @map("period_start")
  periodEnd             DateTime    @map("period_end")
  targetAmount          Decimal     @map("target_amount") @db.Decimal(15, 2)
  achievedAmount        Decimal     @default(0.00) @map("achieved_amount") @db.Decimal(15, 2)
  
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, periodStart, periodEnd])
  @@map("seller_goals")
}

model SellerCommission {
  id                    String      @id @default(uuid())
  userId                String      @map("user_id")
  saleId                String      @map("sale_id")
  amount                Decimal     @db.Decimal(15, 2)
  status                SellerCommissionStatus @default(PENDING)

  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  sale                  Sale        @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("seller_commissions")
}

model ExchangeReturn {
  id                    String      @id @default(uuid())
  companyId             String      @map("company_id")
  originalSaleId        String      @map("original_sale_id")
  customerId            String?     @map("customer_id")
  type                  ExchangeReturnType
  totalCredit           Decimal     @map("total_credit") @db.Decimal(15, 2)
  status                ExchangeReturnStatus @default(PENDING)
  exchangeReason        String?     @map("exchange_reason")
  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")

  company               Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items                 ExchangeReturnItem[]

  @@map("exchange_returns")
}

model ExchangeReturnItem {
  id                    String      @id @default(uuid())
  exchangeReturnId      String      @map("exchange_return_id")
  variantId             String      @map("variant_id")
  quantity              Decimal     @db.Decimal(10, 2)
  condition             ExchangeReturnCondition

  exchangeReturn        ExchangeReturn @relation(fields: [exchangeReturnId], references: [id], onDelete: Cascade)
  variant               ProductVariant @relation(fields: [variantId], references: [id])

  @@map("exchange_return_items")
}
